{
    "datasets":[
        {
            "filepath-train": "./data/ideology_news-dataset_for_training.csv",
            "name": "ideology_news",
            "text_col": "content",
            "label_col": "bias_text",
            "labels": ["left", "right", "center"],
            "id_col": "ID",
            "filepath-predict": "./data/ideology_news-dataset_for_inference.csv",
            "extra_cols_to_keep" : ["year"]
        }
    ],
    "parameters":{
        "N_annotated": [
            500, 
            1000, 
            1500, 
            2000
        ],
        "splits_ratio": [
            [80, 10, 10],
            [70, 15, 15],
            [50, 10, 40]
        ],
        "sampling_method" : [
            {"balance":"random"},
            {"balance":0.25},
            {"balance":0.50},
            {"balance":0.75},
            {"balance":"random", "stratified": "year"},
            {"balance":0.25    , "stratified": "year"},
            {"balance":0.50    , "stratified": "year"},
            {"balance":0.75    , "stratified": "year"}
        ],
        "model_name": [
            "google-bert/bert-base-uncased"
        ],
        "learning_rate":[
            5e-4,
            1e-4,
            1e-5, 
            2e-5, 
            5e-5
        ],
        "weight_decay":[
            0.0,
            0.01,
            0.03,
            0.1
        ], 
        "batch_size":[8, 16, 32], 
        "seed" : [42]
    }
}